{
  "type": "confirmation",
  "title": {
    "translate": "dialog.vas.glow_cooldown.title"
  },
  "body": {
    "type": "plain_message",
    "contents": {
      "translate": "dialog.vas.glow_cooldown.info"
    },
    "width": 300
  },
  "yes": {
    "label": {
      "translate": "dialog.vas.glow_cooldown.yes"
    },
    "action": {
      "type": "dynamic/run_command",
      "template": "trigger vas.rule.glow_cooldown set $(time)"
    }
  },
  "no": {
    "label": {
      "translate": "dialog.vas.no"
    },
    "action": {
      "type": "show_dialog",
      "dialog": "vas:welcomes/rules"
    }
  },
  "inputs": [
    {
      "key": "time",
      "type": "number_range",
      "start": 1,
      "end": 60,
      "initial": 5,
      "label": {
        "translate": "dialog.vas.glow_cooldown.label.time"
      },
      "step": 1
    }
  ]
}